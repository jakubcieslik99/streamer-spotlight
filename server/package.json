{
  "name": "streamer-spotlight-server",
  "version": "1.5.0",
  "description": "Streamer Spotlight",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "docker": "cross-env DIR=streamer-spotlight-server docker-compose -f docker-compose.dev.yml -p streamer-spotlight-server up --force-recreate",
    "dev": "cross-env ENV=development nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "update:all": "corepack up && pnpm update"
  },
  "author": "Jakub Cieślik",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "joi": "^18.1.2",
    "mongoose": "^9.6.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-slow-down": "^2.0.0",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
